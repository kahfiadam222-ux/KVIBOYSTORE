# ─────────────────────────────────────────────────────────────
# kviboystore — Environment Variables
# Copy this file to .env.local and fill in real credentials.
# Never commit .env.local (it is gitignored).
# ─────────────────────────────────────────────────────────────

# Supabase — find these in your project's Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
# Service role key BYPASSES Row Level Security — keep it server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# Xendit — payment gateway (https://dashboard.xendit.co)
XENDIT_SECRET_KEY=xnd_development_your-secret-key
# Token Xendit sends in the x-callback-token header to /api/webhooks/xendit.
# Set the same value in Xendit dashboard → Settings → Webhooks.
XENDIT_WEBHOOK_TOKEN=your-webhook-verification-token

# Public site URL used for OAuth redirects and payment redirect URLs.
# Local dev:  http://localhost:3000
# Production: https://your-domain.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Secret required by Vercel Cron to call /api/cron/auto-confirm.
# Generate a random string, e.g.: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret-here
